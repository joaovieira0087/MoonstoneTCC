@model JogoListViewModel

<div class="container my-5 page-transition">
    @* Cabeçalho de Resultados *@
    <div class="search-header mb-5">
        <h2 class="display-6 fw-bold text-white mb-2">@Model.CategoriaAtual</h2>
        <div class="header-divider"></div>
    </div>

    @* --- CASO 1: ENCONTROU RESULTADOS (Mostra sugestões no topo + Itens) --- *@
    @if (Model.Jogos.Any() || (Model.Acessorios != null && Model.Acessorios.Any()))
    {
        @* Sugestões no topo como "Relacionados" *@
        @if (Model.SugestoesTermos != null && Model.SugestoesTermos.Any())
        {
            <div class="sugestoes-wrapper mb-5">
                <div class="sugestoes-glass">
                    <div class="d-flex align-items-center mb-3">
                        <div class="icon-sparkle">
                            <i class="fa-solid fa-wand-magic-sparkles"></i>
                        </div>
                        <span class="sugestoes-label">Buscas relacionadas:</span>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var termo in Model.SugestoesTermos)
                        {
                            <a asp-controller="Jogo" asp-action="Search" asp-route-searchString="@termo"
                               class="pill-sugestao">
                                <i class="fa-solid fa-magnifying-glass small me-1 opacity-50"></i>
                                @termo
                            </a>
                        }
                    </div>
                </div>
            </div>
        }

        @* Listagem de Jogos *@
        @if (Model.Jogos.Any())
        {
            <div class="section-title-wrapper mb-4 mt-2">
                <h3 class="section-title"><i class="fa-solid fa-gamepad me-2 text-accent"></i>Jogos Disponíveis</h3>
            </div>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4 mb-5">
                @foreach (var jogo in Model.Jogos)
                {
                    <div class="col card-hover-effect">
                        <partial name="_JogosResumo" for="@jogo" />
                    </div>
                }
            </div>
        }

        @* Listagem de Acessórios *@
        @if (Model.Acessorios?.Any() == true)
        {
            <div class="section-title-wrapper mb-4 mt-5">
                <h3 class="section-title"><i class="fa-solid fa-headset me-2 text-accent"></i>Acessórios</h3>
            </div>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-4">
                @foreach (var acessorio in Model.Acessorios)
                {
                    <div class="col card-hover-effect">
                        <partial name="_AcessorioResumo" for="@acessorio" />
                    </div>
                }
            </div>
        }
    }
    else
    @* --- CASO 2: NÃO ENCONTROU NADA (Mostra sugestões dentro do Empty State) --- *@
    {
        <div class="empty-state">
            <div class="empty-icon-wrapper">
                <i class="fa-solid fa-ghost fa-4x mb-4"></i>
            </div>
            <h4 class="text-white">Ops! Não encontramos nada...</h4>
            <p class="text-muted">Não achamos o que você buscou, mas que tal dar uma olhada nisso:</p>

            @if (Model.SugestoesTermos != null && Model.SugestoesTermos.Any())
            {
                <div class="d-flex flex-wrap justify-content-center gap-2 mt-4">
                    @foreach (var termo in Model.SugestoesTermos)
                    {
                        <a asp-controller="Jogo" asp-action="Search" asp-route-searchString="@termo"
                           class="pill-sugestao">
                            <i class="fa-solid fa-fire-flame-curved me-1 opacity-50"></i>
                            @termo
                        </a>
                    }
                </div>
            }

            <div class="mt-4 pt-3">
                <a asp-action="List" class="btn btn-outline-purple">Explorar todos os jogos</a>
            </div>
        </div>
    }
</div>

<style>
    /* Variáveis de Cor */
    :root {
        --accent-purple: #b84dff;
        --deep-purple: #3A0066;
        --glass-bg: rgba(255, 255, 255, 0.05);
        --text-accent: #d199ff;
    }

    /* Animação de Entrada */
    .page-transition {
        animation: fadeIn 0.6s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Header */
    .header-divider {
        height: 4px;
        width: 60px;
        background: linear-gradient(90deg, var(--accent-purple), transparent);
        border-radius: 2px;
    }

    /* Estilo Glassmorphism para Sugestões */
    .sugestoes-glass {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }

    .icon-sparkle {
        color: var(--accent-purple);
        font-size: 1.2rem;
        margin-right: 12px;
        filter: drop-shadow(0 0 5px var(--accent-purple));
    }

    .sugestoes-label {
        color: #cfc9d9;
        font-weight: 600;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        font-size: 0.75rem;
    }

    /* Pills (Tags) */
    .pill-sugestao {
        background: rgba(184, 77, 255, 0.15);
        border: 1px solid rgba(184, 77, 255, 0.3);
        color: var(--text-accent);
        padding: 8px 18px;
        border-radius: 50px;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
    }

        .pill-sugestao:hover {
            background: var(--accent-purple);
            color: white !important;
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 8px 20px rgba(184, 77, 255, 0.4);
            border-color: white;
        }

    /* Títulos de Seção */
    .section-title {
        font-weight: 800;
        color: white;
        font-size: 1.5rem;
        position: relative;
    }

    .text-accent {
        color: var(--text-accent);
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: rgba(255,255,255, 0.02);
        border-radius: 30px;
        border: 2px dashed rgba(255,255,255, 0.1);
    }

    .empty-icon-wrapper {
        color: rgba(255,255,255, 0.1);
        animation: float 3s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-15px);
        }
    }

    .btn-outline-purple {
        border-color: var(--accent-purple);
        color: var(--accent-purple);
        border-radius: 50px;
        padding: 10px 25px;
        font-weight: 700;
    }

        .btn-outline-purple:hover {
            background: var(--accent-purple);
            color: white;
            box-shadow: 0 0 15px var(--accent-purple);
        }

    /* Efeito nos Cards */
    .card-hover-effect {
        transition: transform 0.3s ease;
    }

        .card-hover-effect:hover {
            z-index: 2;
        }
</style>